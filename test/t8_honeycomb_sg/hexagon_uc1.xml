<sg name="hexagon_uc1" format="1">
    <!-- <include>
        <material>materials</material>
    </include> -->

    <analysis>
        <model_dim>3</model_dim>
    </analysis>

    <general>
        <!-- <translate>1 2</translate>
    <scale></scale>
    <rotate>30</rotate> -->
        <mesh_size>0.04</mesh_size>
        <element_type>2</element_type>
        <omega>20.485</omega>
    </general>

    <baselines>
        <point name="o">0  0</point>
        <point name="p1">0 2</point>
        <point name="p2">-1.732 1</point>
        <point name="p3">-1.732 -1</point>
        <point name="p4">0 -2</point>
        <point name="p5">1.732 -1</point>
        <point name="p6">1.732 1</point>
        <point name="pt">0 3</point>
        <point name="pb">0 -3</point>

        <line name="ln_hex">
            <points>p1,p2,p3,p4,p5,p6,p1</points>
        </line>
        <line name="ln_hex_tr">
            <points>pt,p1,p6</points>
        </line>
        <line name="ln_hex_tl">
            <points>p2,p1,pt</points>
        </line>
        <line name="ln_hex_bl">
            <points>pb,p4,p3</points>
        </line>
        <line name="ln_hex_br">
            <points>p5,p4,pb</points>
        </line>
    </baselines>

    <materials>
        <material name="aluminum" type="isotropic">
            <density>2700</density>
            <elastic>
                <e>70e9</e>
                <nu>0.33</nu>
            </elastic>
        </material>
        <lamina name="la_m1">
            <material>aluminum</material>
            <thickness>0.01</thickness>
        </lamina>
    </materials>

    <layups>
        <layup name="layup1">
            <layer lamina="la_m1">0:5</layer>
        </layup>
    </layups>

    <component name="hex">
        <segment>
            <baseline>ln_hex</baseline>
            <layup>layup1</layup>
        </segment>
    </component>
    <component name="hex_tr">
        <segment>
            <baseline>ln_hex_tr</baseline>
            <layup>layup1</layup>
            <trim>
                <location>tail</location>
                <direction>0 1</direction>
            </trim>
        </segment>
    </component>
    <component name="hex_tl">
        <segment>
            <baseline>ln_hex_tl</baseline>
            <layup>layup1</layup>
            <trim>
                <location>head</location>
                <direction>0 1</direction>
            </trim>
        </segment>
    </component>
    <component name="hex_bl">
        <segment>
            <baseline>ln_hex_bl</baseline>
            <layup>layup1</layup>
            <trim>
                <location>tail</location>
                <direction>0 1</direction>
            </trim>
        </segment>
    </component>
    <component name="hex_br">
        <segment>
            <baseline>ln_hex_br</baseline>
            <layup>layup1</layup>
            <trim>
                <location>head</location>
                <direction>0 1</direction>
            </trim>
        </segment>
    </component>



</sg>
