<cross_section name="ibeam">
    <include>
        <material>materials</material>
    </include>

    <general>
        <translate>0.0 0.0</translate>
        <scale>1.0</scale>
        <rotate>0.0</rotate>
        <mesh_size>0.02</mesh_size>
        <element_type>linear</element_type>
    </general>

    <baselines>

        <point name="tl">-1.2 0</point>
        <point name="tr">1.2 0</point>
        <point name="br">1.5 -3.5</point>
        <point name="bl">-1.5 -3.5</point>
        
        <line name="bl_top">
            <points>tl,tr</points>
        </line>
        <line name="bl_bottom">
            <points>bl,br</points>
        </line>

        <point name="web">0.04 -2</point>
        <line name="bl_web">
            <point>web</point>
            <angle>90</angle>
        </line>

    </baselines>

    <layups>
        <layup name="layup_1">
            <layer lamina="la_iso5_1_003">90:2</layer>
            <layer lamina="la_iso5_2_005">0</layer>
        </layup>
        <layup name="layup_2">
            <layer lamina="la_iso5_3_0015">0:3</layer>
            <layer lamina="la_iso5_4_002">90</layer>
        </layup>
        <layup name="layup_web">
            <layer lamina="la_iso5_5_002">0:6</layer>
        </layup>
    </layups>

    <component name="top">
        <segment name="sgtop">
            <baseline>bl_top</baseline>
            <layup direction="right">layup_1</layup>
        </segment>
    </component>

    <component name="bottom">
        <segment name="sgbottom">
            <baseline>bl_bottom</baseline>
            <layup>layup_2</layup>
        </segment>
    </component>

    <component name="web" depend="top,bottom">
        <segment>
            <baseline>bl_web</baseline>
            <layup>layup_web</layup>
        </segment>
    </component>

</cross_section>
