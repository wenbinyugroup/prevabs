<cross_section name="airfoil_skin_only">

  <include>
    <material>materials</material>
  </include>

  <analysis>
    <!-- Timoshenko beam model -->
    <model>1</model>
  </analysis>


  <general>
    <translate>-0.25 0.0</translate>
    <scale>1.0</scale>
    <mesh_size>0.0025</mesh_size>
    <element_shape>tri</element_shape>
    <element_type>linear</element_type>
  </general>

  <baselines>

    <line name="ln_af" type="airfoil">
      <points data="file" format="1" header="1">a18sm.dat</points>
      <leading_edge>0.000000 0.001104</leading_edge>
      <trailing_edge>1.000000 0.000148</trailing_edge>
    </line>

  </baselines>

  <materials>
    <lamina name="ply">
      <material>al_alloy</material>
      <thickness>0.01</thickness>
    </lamina>
  </materials>

  <layups>
    <layup name="layup1">
      <layer lamina="ply">0.0</layer>
    </layup>
  </layups>


  <!-- Surface layup -->
  <component name="surface">
    <segment name="sg_le">
      <baseline>ln_af</baseline>
      <layup>layup1</layup>
    </segment>
  </component>

</cross_section>
