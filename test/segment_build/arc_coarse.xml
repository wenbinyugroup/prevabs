<cross_section name="arc_coarse" format="1">
  <!-- 90-degree arc, coarse discretisation (~9 segments), 3 layers. -->
  <include><material>materials</material></include>
  <general>
    <mesh_size>0.03</mesh_size>
    <element_type>linear</element_type>
  </general>
  <baselines>
    <point name="ct">0 0</point>
    <point name="ptop">0 2</point>
    <point name="pleft">-2 0</point>
    <baseline name="bl" type="arc">
      <center>ct</center>
      <start>ptop</start>
      <end>pleft</end>
      <discrete by="angle">10</discrete>
      <direction>ccw</direction>
    </baseline>
  </baselines>
  <layups>
    <layup name="lp" method="ss">
      <lamina>la_010</lamina>
      <code>[0/90/0]</code>
    </layup>
  </layups>
  <component name="c">
    <segment>
      <baseline>bl</baseline>
      <layup>lp</layup>
    </segment>
  </component>
</cross_section>
