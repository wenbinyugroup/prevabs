<cross_section name="circle_closed" format="1">
  <!-- Closed baseline (full circle). Edge case: the layered path does not yet
       tile a CLOSED multi-layer loop, so this is expected to fall back to the
       legacy path (route=legacy in the dump). Documents the closed-loop gap
       called out in note-build-laminate-segment.md 2.1.3. -->
  <include><material>materials</material></include>
  <general>
    <mesh_size>0.03</mesh_size>
    <element_type>linear</element_type>
  </general>
  <baselines>
    <point name="ct">0 0</point>
    <baseline name="bl" type="circle">
      <center>ct</center>
      <radius>2</radius>
      <discrete by="angle">10</discrete>
      <direction>ccw</direction>
    </baseline>
  </baselines>
  <layups>
    <layup name="lp" method="ss">
      <lamina>la_010</lamina>
      <code>[0/90/0]</code>
    </layup>
  </layups>
  <component name="c">
    <segment>
      <baseline>bl</baseline>
      <layup>lp</layup>
    </segment>
  </component>
</cross_section>
