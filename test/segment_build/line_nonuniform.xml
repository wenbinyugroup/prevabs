<cross_section name="line_nonuniform" format="1">
  <!-- Non-uniform per-layer thickness via the "layer list" method:
       0.005 / 0.010 / 0.020 stacked. Exercises route-ii per-layer offset
       where each layer curve is offset from the previous by a DIFFERENT
       thickness. -->
  <include><material>materials</material></include>
  <general>
    <mesh_size>0.01</mesh_size>
    <element_type>linear</element_type>
  </general>
  <baselines>
    <point name="lc">-1 0</point>
    <point name="rc"> 1 0</point>
    <baseline name="bl" type="straight"><points>lc,rc</points></baseline>
  </baselines>
  <layups>
    <layup name="lp" method="layer list">
      <layer lamina="la_005">0</layer>
      <layer lamina="la_010">90</layer>
      <layer lamina="la_020">0</layer>
    </layup>
  </layups>
  <component name="c">
    <segment>
      <baseline>bl</baseline>
      <layup>lp</layup>
    </segment>
  </component>
</cross_section>
