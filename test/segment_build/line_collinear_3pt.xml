<cross_section name="line_collinear_3pt" format="1">
  <!-- Extracted verbatim from integration t1_strip/strip_two_lines (segment
       sgm_1). Open straight baseline with a REDUNDANT collinear interior
       vertex (lc,mc,rc all on y=0) plus a 16-ply symmetric layup. The layered
       offset route falls back to legacy on this segment. Parameters unchanged. -->
  <general>
    <translate>0.0 0.0</translate>
    <scale>1.0</scale>
    <rotate>0.0</rotate>
    <mesh_size>0.01</mesh_size>
    <element_type>linear</element_type>
  </general>

  <baselines>
    <point name="lc">-1 0</point>
    <point name="mc">0 0</point>
    <point name="rc">1 0</point>
    <baseline name="bl" type="straight">
      <points>lc,mc,rc</points>
    </baseline>
  </baselines>

  <materials>
    <material name="iso5_1" type="orthotropic">
      <density>1.86E+03</density>
      <elastic>
        <e1>3.70E+10</e1>
        <e2>9.00E+09</e2>
        <e3>9.00E+09</e3>
        <g12>4.00E+09</g12>
        <g13>4.00E+09</g13>
        <g23>4.00E+09</g23>
        <nu12>0.28</nu12>
        <nu13>0.28</nu13>
        <nu23>0.28</nu23>
      </elastic>
      <failure_criterion>tsai-wu</failure_criterion>
      <characteristic_length>0</characteristic_length>
      <strength>
        <xt>1</xt>
        <xc>2</xc>
        <yt>3</yt>
        <yc>4</yc>
        <zt>5</zt>
        <zc>6</zc>
        <r>7</r>
        <t>8</t>
        <s>9</s>
      </strength>
    </material>
    <lamina name="la_iso5_1_0005">
      <material>iso5_1</material>
      <thickness>0.005</thickness>
    </lamina>
  </materials>

  <layups>
    <layup name="layup1" method="ss">
      <lamina>la_iso5_1_0005</lamina>
      <code>[45:2/-45:2/0:2/90:2]s</code>
    </layup>
  </layups>

  <component name="top">
    <segment>
      <baseline>bl</baseline>
      <layup>layup1</layup>
    </segment>
  </component>
</cross_section>
