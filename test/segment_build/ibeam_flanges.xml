<cross_section name="ibeam_flanges" format="1">
  <!-- Extracted verbatim from integration t4_I/i_web (segments sgtop, sgbottom).
       The two collinear-3-point flange baselines with 2-ply explicit layups.
       Both flange segments fall back from the layered offset route to legacy.
       The web segment (which depends on the flanges) is dropped; flange
       parameters are unchanged. -->
  <general>
    <translate>0.0 0.0</translate>
    <scale>1.0</scale>
    <rotate>0.0</rotate>
    <mesh_size>0.02</mesh_size>
    <element_type>linear</element_type>
  </general>

  <baselines>
    <point name="tl">-1 0</point>
    <point name="tc">0 0</point>
    <point name="tr">1 0</point>
    <point name="br">1.5 -3</point>
    <point name="bc">0 -3</point>
    <point name="bl">-1.5 -3</point>

    <baseline name="bl_top" type="straight">
      <points>tl,tc,tr</points>
    </baseline>
    <baseline name="bl_bottom" type="straight">
      <points>bl,bc,br</points>
    </baseline>
  </baselines>

  <materials>
    <material name="iso5_1" type="orthotropic">
      <density>1.86E+03</density>
      <elastic>
        <e1>3.70E+10</e1>
        <e2>9.00E+09</e2>
        <e3>9.00E+09</e3>
        <g12>4.00E+09</g12>
        <g13>4.00E+09</g13>
        <g23>4.00E+09</g23>
        <nu12>0.28</nu12>
        <nu13>0.28</nu13>
        <nu23>0.28</nu23>
      </elastic>
    </material>
    <lamina name="la_iso5_1_003">
      <material>iso5_1</material>
      <thickness>0.03</thickness>
    </lamina>

    <material name="iso5_2" type="orthotropic">
      <density>1.83E+03</density>
      <elastic>
        <e1>1.03E+10</e1>
        <e2>1.03E+10</e2>
        <e3>1.03E+10</e3>
        <g12>8.00E+09</g12>
        <g13>8.00E+09</g13>
        <g23>8.00E+09</g23>
        <nu12>0.30</nu12>
        <nu13>0.30</nu13>
        <nu23>0.30</nu23>
      </elastic>
    </material>
    <lamina name="la_iso5_2_005">
      <material>iso5_2</material>
      <thickness>0.05</thickness>
    </lamina>

    <material name="iso5_3" type="orthotropic">
      <density>1.83E+03</density>
      <elastic>
        <e1>1.00E+01</e1>
        <e2>1.00E+01</e2>
        <e3>1.00E+01</e3>
        <g12>1.00E+00</g12>
        <g13>1.00E+00</g13>
        <g23>1.00E+00</g23>
        <nu12>0.30</nu12>
        <nu13>0.30</nu13>
        <nu23>0.30</nu23>
      </elastic>
    </material>
    <lamina name="la_iso5_3_0015">
      <material>iso5_3</material>
      <thickness>0.015</thickness>
    </lamina>

    <material name="iso5_4" type="orthotropic">
      <density>1.664E+03</density>
      <elastic>
        <e1>1.03E+10</e1>
        <e2>1.03E+10</e2>
        <e3>1.03E+10</e3>
        <g12>8.00E+09</g12>
        <g13>8.00E+09</g13>
        <g23>8.00E+09</g23>
        <nu12>0.30</nu12>
        <nu13>0.30</nu13>
        <nu23>0.30</nu23>
      </elastic>
    </material>
    <lamina name="la_iso5_4_002">
      <material>iso5_4</material>
      <thickness>0.02</thickness>
    </lamina>
  </materials>

  <layups>
    <layup name="layup_1">
      <layer lamina="la_iso5_1_003">90:2</layer>
      <layer lamina="la_iso5_2_005">0</layer>
    </layup>
    <layup name="layup_2">
      <layer lamina="la_iso5_3_0015">0:3</layer>
      <layer lamina="la_iso5_4_002">90</layer>
    </layup>
  </layups>

  <component name="top">
    <segment name="sgtop">
      <baseline>bl_top</baseline>
      <layup>layup_1</layup>
    </segment>
  </component>
  <component name="bottom">
    <segment name="sgbottom">
      <baseline>bl_bottom</baseline>
      <layup>layup_2</layup>
    </segment>
  </component>
</cross_section>
