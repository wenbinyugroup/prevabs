<cross_section name="s" format="1">
  <include>
    <material>materials</material>
  </include>

  <analysis>
    <model>1</model>
  </analysis>

  <general>
    <translate>0.0 0.0</translate>
    <scale>1.0</scale>
    <rotate>0.0</rotate>
    <mesh_size>0.02</mesh_size>
    <element_type>linear</element_type>
  </general>

  <baselines>
    <point name="p1">1 2</point>
    <point name="p2">-1 2</point>
    <point name="p3">0 0</point>
    <point name="p4">-1 -2</point>
    <point name="p5">1 -2</point>
    <baseline name="bl1">
      <points>p1,p2</points>
    </baseline>
    <baseline name="bl2">
      <points>p2,p3,p4</points>
    </baseline>
    <baseline name="bl3">
      <points>p4,p5</points>
    </baseline>
  </baselines>

  <layups>
    <layup name="layup1" method="ss">
      <lamina>la_iso5_1_0005</lamina>
      <code>[0:8/90:8]</code>
    </layup>
    <layup name="layup2" method="ss">
      <lamina>la_iso5_1_0005</lamina>
      <code>[45:12/-45:12]</code>
    </layup>
  </layups>

  <component name="main">
    <segment name="sg1">
      <baseline>bl1</baseline>
      <layup direction="left">layup1</layup>
    </segment>
    <segment name="sg2">
      <baseline>bl2</baseline>
      <layup direction="left">layup2</layup>
    </segment>
    <segment name="sg3">
      <baseline>bl3</baseline>
      <layup direction="left">layup1</layup>
    </segment>
  </component>

</cross_section>