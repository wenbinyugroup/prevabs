<cross_section name="box">

  <analysis>
    <model>1</model>
  </analysis>

  <general>
    <mesh_size>0.01</mesh_size>
    <element_type>2</element_type>
  </general>

  <materials>
    <material name="mtr_lamina" type="transversely isotropic">
      <density>10</density>
      <elastic>
        <e1>4</e1>
        <e2>5</e2>
        <g12>6</g12>
        <nu12>0.4</nu12>
      </elastic>
    </material>
    <lamina name="la_mtr_lamina_0.01">
      <material>mtr_lamina</material>
      <thickness>0.02</thickness>
    </lamina>
  </materials>

  <baselines>

    <point name="o">0  0</point>
    <point name="lb">-0.5 -0.5</point>
    <point name="lt">-0.5  0.5</point>
    <point name="rt">0.5  0.5</point>
    <point name="rb">0.5 -0.5</point>

    <baseline name="bsl_all" type="straight">
      <!-- <points>rt,p1,lt,lb,rb,p8,rt</points> -->
      <!-- <points>rt,p2,lt,p3,p4,lb,p5,p6,rb,p7,rt</points> -->
      <points>rt,lt,lb,rb,rt</points>
    </baseline>

    <line name="ln_web">
      <point>o</point>
      <angle>80</angle>
    </line>

  </baselines>



  <layups>
    <layup name="layup1">
      <layer lamina="la_mtr_lamina_0.01">0:2</layer>
      <layer lamina="la_mtr_lamina_0.01">90:2</layer>
    </layup>

    <layup name="layup2">
      <layer lamina="la_mtr_lamina_0.01">0:2</layer>
    </layup>
  </layups>



  <component name="main">
    <segment>
      <baseline>bsl_all</baseline>
      <layup>layup1</layup>
    </segment>
  </component>

  <component name="web" depend="main">
    <segment>
      <baseline>ln_web</baseline>
      <layup>layup2</layup>
    </segment>
  </component>

  <component name="web_r" depend="main">
    <segment>
      <baseline>ln_web</baseline>
      <layup direction="right">layup2</layup>
    </segment>
  </component>

</cross_section>
