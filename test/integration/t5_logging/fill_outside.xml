<cross_section name="fill_outside">

  <analysis>
    <model>1</model>
  </analysis>

  <general>
    <mesh_size>0.02</mesh_size>
    <element_shape>quad</element_shape>
    <element_type>2</element_type>
  </general>

  <baselines>
    <point name="lb">-0.5 -0.5</point>
    <point name="lt">-0.5 0.5</point>
    <point name="rt">0.5 0.5</point>
    <point name="rb">0.5 -0.5</point>
    <point name="outside">0.8 0.0</point>

    <baseline name="box">
      <points>lb,lt,rt,rb,lb</points>
    </baseline>
  </baselines>

  <materials>
    <material name="foam" type="isotropic">
      <density>160</density>
      <elastic>
        <e>72.400E+09</e>
        <nu>0.3</nu>
      </elastic>
    </material>
  </materials>

  <component name="fill_outside" type="fill">
    <baseline>box</baseline>
    <location>outside</location>
    <material>foam</material>
  </component>

</cross_section>
