<cross_section name="circle_outward">
    <!-- Regression: a ccw circle with a `right` layup grows the laminate
         OUTWARD, so the offset ring is the annulus OUTER boundary and the base
         ring is the inner hole. Exercises the offset-outer nesting branch of the
         closed layered tiler (issue-20260702-closed-annulus-outward-nesting):
         rings are ordered outer->inner and carved from the outside in, with each
         band mapped back to its material layer. -->
    <include>
        <material>materials</material>
    </include>

    <analysis>
        <model>1</model>
    </analysis>

    <general>
        <mesh_size>0.1</mesh_size>
        <element_type>linear</element_type>
    </general>

    <baselines>
        <point name="ct">0 0</point>
        <baseline name="bsl_circle" type="circle">
            <center>ct</center>
            <radius>2</radius>
            <discrete by="angle">10</discrete>
            <direction>ccw</direction>
        </baseline>
    </baselines>

    <layups>
        <layup name="layup1" method="stack sequence">
            <lamina>la_iso5_4_005</lamina>
            <code>[45/-45/0]</code>
        </layup>
    </layups>

    <component name="out">
        <segment>
            <baseline>bsl_circle</baseline>
            <layup direction="right">layup1</layup>
        </segment>
    </component>
</cross_section>
